# GreenSpark backend environment template.
# Copy to .env and fill in. Never commit the real .env (it is git-ignored).

APP_ENV=development

# SQLite during the research MVP (PostgreSQL when scaling).
DATABASE_URL=sqlite:///./database/greenspark.db

# Optional LLM explanatory agent (DeepSeek, OpenAI-compatible).
# Leave AI_PROVIDER_API_KEY empty to use the deterministic fallback.
AI_PROVIDER_API_KEY=
AI_MODEL=deepseek-chat
AI_BASE_URL=https://api.deepseek.com
AI_TIMEOUT_SECONDS=20

# Comma-separated allowed CORS origins for the React frontend ("*" allows all).
CORS_ORIGINS=*

# Traceability stamps recorded with predictions and reports.
MODEL_VERSION=baseline-v0.1
DATASET_VERSION=literature-2025-v1
REPORT_GENERATOR_VERSION=report-gen-v0.1
